# ============================================================
# KoraStay - Exemple de variables d'environnement
# Copiez ce fichier en .env (local) ou renseignez ces variables
# dans Vercel (Project Settings > Environment Variables).
# ============================================================

# --- Base de donnees PostgreSQL (Neon) ---
# Runtime : connexion POOLEE (-pooler + pgbouncer=true) pour le serverless.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true"
# Migrations / prisma db push : connexion DIRECTE (sans -pooler).
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# --- Securite des sessions (chaine aleatoire longue) ---
AUTH_SECRET="changez-moi-par-une-chaine-aleatoire-de-32-caracteres-minimum"

# --- Application ---
NEXT_PUBLIC_APP_NAME="KoraStay"
NEXT_PUBLIC_APP_URL="https://votre-domaine.vercel.app"
APP_URL="https://votre-domaine.vercel.app"

# --- Email (optionnel : Resend si une cle est fournie) ---
EMAIL_FROM="KoraStay <contact@korastay.com>"
RESEND_API_KEY=""

# --- Paiement (mock par defaut) ---
PAYMENT_PROVIDER="mock"

# --- Upload (local en dev ; voir DEPLOY.md pour Vercel Blob) ---
UPLOAD_PROVIDER="local"

# --- Contact affiche publiquement ---
NEXT_PUBLIC_CONTACT_EMAIL="contact@korastay.com"
NEXT_PUBLIC_CONTACT_PHONE="+225 07 57 90 88 84"

# Affiche les images distantes de demonstration (mettre "true")
NEXT_PUBLIC_USE_REMOTE_IMAGES="true"
